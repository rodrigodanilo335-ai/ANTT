# ========================================
# DATABASE CONFIGURATION
# ========================================
DATABASE_URL="postgresql://antt_user:antt_password@localhost:5432/antt_db"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antt_db
DB_USER=antt_user
DB_PASSWORD=antt_password

# ========================================
# FRONTEND CONFIGURATION
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ANTT
NEXT_PUBLIC_APP_DESCRIPTION="Agência Nacional de Transportes Terrestres Virtual"

# ========================================
# BACKEND CONFIGURATION
# ========================================
PORT=3001
NODE_ENV=development
APP_NAME=ANTT API
APP_DESCRIPTION="ANTT Backend API"
API_VERSION=v1
APP_PREFIX=api

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRATION=30d

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:3000

# ========================================
# OAUTH CONFIGURATION
# ========================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# ========================================
# SUPABASE STORAGE CONFIGURATION
# ========================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key
SUPABASE_STORAGE_BUCKET=antt-uploads

# ========================================
# EMAIL CONFIGURATION
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@antt.com
SMTP_FROM_NAME=ANTT Platform

# ========================================
# DISCORD CONFIGURATION
# ========================================
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_BOT_TOKEN=your_discord_bot_token

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# 2FA CONFIGURATION
# ========================================
TWO_FACTOR_ENABLED=true

# ========================================
# AWS CONFIGURATION (Optional)
# ========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=antt-bucket

# ========================================
# PAYMENT CONFIGURATION (Optional)
# ========================================
STRIPE_PUBLIC_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_

# ========================================
# SENTRY CONFIGURATION (Optional)
# ========================================
SENTRY_DSN=your_sentry_dsn
